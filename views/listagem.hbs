<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>Celular</th>
            <th>E-mail</th>
            <th style="width: 180px;">Data de Cadastro</th>
        </tr>
    </thead>
    <tbody>
        {{#each pacientes}}
        <tr>
            <td class="fw-bold">{{this.nome}}</td>
            <td>{{this.celular}}</td>
            <td>{{this.email}}</td>
            <td class="text-muted small">{{this.criado_em}}</td>
        </tr>
        {{else}}
        <tr>
            <td colspan="4" class="text-center text-muted py-4">
                Nenhum paciente encontrado no sistema.
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>
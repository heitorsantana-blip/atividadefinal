<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h2 class="text-center mb-4">Cadastro de Paciente</h2>
            
            <form action="/pacientes/cadastrar" method="POST">
                <div class="mb-3">
                    <label for="nome" class="form-label">Nome Completo</label>
                    <input type="text" class="form-control" id="nome" name="nome" placeholder="Ex: João Silva" required>
                </div>

                <div class="mb-3">
                    <label for="celular" class="form-label">Celular</label>
                    <input type="tel" class="form-control" id="celular" name="celular" placeholder="(00) 00000-0000" required>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">E-mail</label>
                    <input type="email" class="form-control" id="email" name="email" placeholder="nome@email.com" required>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">Finalizar Cadastro</button>
                    <a href="/" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>

                        <div class="text-center mt-3">
                <p>Já possui cadastros? <a href="/listagem">Visualizar lista completa</a></p>
            </div>
        </div>
    </div>
</div>